generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  apiKey                 String    @unique @map("api_key")
  stripeCustomerId       String?   @map("stripe_customer_id")
  stripeSubscriptionId   String?   @map("stripe_subscription_id")
  plan                   String    @default("free")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  
  domains                Domain[]
  emails                 Email[]
  variants               EmailVariant[]
  flows                  Flow[]
  contacts               Contact[]
  executions             FlowExecution[]
  suppressions           Suppression[]
  warmupConfigs          WarmupConfig[]
  webhookConfigs         WebhookConfig[]
  agencyConfigs          AgencyConfig[]
  segments               Segment[]

  @@map("projects")
}

model Domain {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  domainName        String   @map("domain_name")
  isVerified        Boolean  @default(false) @map("is_verified")
  verificationToken String   @map("verification_token")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("domains")
}

model Email {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  fromEmail      String   @map("from_email")
  toEmail        String   @map("to_email")
  subject        String
  bodyHtml       String?  @map("body_html")
  bodyText       String?  @map("body_text")
  status         String   @default("pending")
  opens          Int      @default(0)
  clicks         Int      @default(0)
  variantId      String?  @map("variant_id") @db.Uuid
  localOpenHour  Int?     @map("local_open_hour")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("emails")
}

model EmailVariant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  subject     String
  bodyHtml    String?  @map("body_html")
  bodyText    String?  @map("body_text")
  sends       Int      @default(0)
  opens       Int      @default(0)
  isWinner    Boolean  @default(false) @map("is_winner")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("email_variants")
}

model Flow {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  name         String
  triggerType  String   @map("trigger_type")
  graph        Json
  isActive     Boolean  @default(false) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions   FlowExecution[]
  suggestions  FlowSuggestion[]

  @@map("flows")
}

model Contact {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  email       String
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  attributes  Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userEvents  UserEvent[]

  @@unique([projectId, email])
  @@index([projectId, email])
  @@map("contacts")
}

model UserEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  contactId   String   @map("contact_id") @db.Uuid
  eventName   String   @map("event_name")
  properties  Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("user_events")
}

model FlowExecution {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId       String   @map("flow_id") @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  status       String   @default("running")
  contextData  Json     @default("{}") @map("context_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("flow_executions")
}

model FlowSuggestion {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId    String   @map("flow_id") @db.Uuid
  nodeId    String?  @map("node_id") // Optional: link to specific React Flow node
  content   String   // The AI recommendation
  priority  String   @default("medium") // low, medium, high
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("flow_suggestions")
}

model Suppression {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  email       String
  reason      String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@map("suppressions")
}

model WarmupConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  dailyLimit    Int      @default(50) @map("daily_limit")
  currentCount  Int      @default(0) @map("current_count")
  lastResetAt   DateTime @default(now()) @map("last_reset_at") @db.Timestamptz

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId])
  @@map("warmup_configs")
}

model WebhookConfig {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  url         String
  secretKey   String   @map("secret_key")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("webhook_configs")
}

model WebhookDelivery {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookConfigId  String   @map("webhook_config_id") @db.Uuid
  eventType        String   @map("event_type")
  payload          Json
  statusCode       Int?     @map("status_code")
  attempts         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([webhookConfigId])
  @@map("webhook_deliveries")
}

model AgencyConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  customDomain  String   @unique @map("custom_domain")
  logoUrl       String?  @map("logo_url")
  brandColor    String?  @map("brand_color")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([customDomain])
  @@map("agency_configs")
}

model IdempotencyKey {
  key        String   @id @map("idempotency_key")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("idempotency_keys")
}

model Segment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  rules       Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("segments")
}

// Better Auth Models
model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String    @unique
  emailVerified Boolean   @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id") @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("account")
}

model Verification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("verification")
}
