# Database (Neon / Prisma)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Better Auth Configuration
BETTER_AUTH_SECRET=your-random-secret-here
BETTER_AUTH_URL=http://localhost:3001 # API URL

# Supabase Configuration (Legacy / Support)
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AWS SES Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Upstash Configuration (for Workflows & Redis)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
UPSTASH_WORKFLOW_URL=https://your-api.com/workflow
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# API Configuration
FLOWMAIL_API_URL=http://localhost:3001
DASHBOARD_API_KEY=your-internal-api-key
URL_SIGNING_SECRET=your-url-signing-secret

# Google AI Studio (Gemini 2.0 Flash)
GOOGLE_AI_API_KEY=your-google-ai-key-here

# AI & ML Configuration
STO_LAMBDA_URL=https://your-lambda-url.amazonaws.com/

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...
