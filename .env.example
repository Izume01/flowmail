# Supabase Configuration
# API side (Service Role for admin/internal ops)
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Web side (Public for auth/direct logs access if needed)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AWS SES Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Upstash Configuration (for Workflows)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
UPSTASH_WORKFLOW_URL=https://your-api.com/workflow

# API Configuration
# Dashboard uses this to talk to the API
FLOWMAIL_API_URL=http://localhost:3001
DASHBOARD_API_KEY=your-internal-api-key

# AI & ML Configuration
STO_LAMBDA_URL=https://your-lambda-url.amazonaws.com/
